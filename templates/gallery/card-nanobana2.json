{
  "name": "Nano Bana2 Business Card",
  "description": "High-fidelity professional business card matching the Nano Bana2 tech suite.",
  "collection": "nano-bana2-suite",
  "config": {
    "fullName": "{{fullName}}",
    "jobTitle": "{{jobTitle}}",
    "accentColor": "#00ffff",
    "theme": "glass",
    "printableCard": {
      "dimensions": { "width": 1050, "height": 600 },
      "background": { "color": "#0a0f1e" },
      "layers": [
        {
          "type": "rectangle",
          "x": 0, "y": 0, "width": 10, "height": 600,
          "style": { "color": "#00ffff" }
        },
        {
          "type": "text",
          "content": "{{fullName}}",
          "x": 80,
          "y": 140,
          "style": { "size": 72, "color": "white", "weight": "bold", "font": "Inter-Bold" }
        },
        {
          "type": "text",
          "content": "{{jobTitle}}",
          "x": 80,
          "y": 210,
          "style": { "size": 32, "color": "#00ffff", "weight": "bold", "font": "Inter-Regular", "letterSpacing": 4 }
        },
        {
          "type": "text",
          "content": "{{companyName}}",
          "x": 80,
          "y": 280,
          "style": { "size": 28, "color": "#94a3b8", "font": "Inter-Regular" }
        },
        {
          "type": "line",
          "x1": 80, "y1": 340, "x2": 400, "y2": 340,
          "style": { "color": "rgba(0, 255, 255, 0.2)", "width": 2 }
        },
        {
          "type": "text",
          "content": "{{userEmail}}",
          "x": 80,
          "y": 420,
          "style": { "size": 24, "color": "white", "font": "Inter-Regular" }
        },
        {
          "type": "text",
          "content": "{{userPhone}}",
          "x": 80,
          "y": 470,
          "style": { "size": 24, "color": "white", "font": "Inter-Regular" }
        },
        {
          "type": "text",
          "content": "@{{githubUsername}}",
          "x": 80,
          "y": 520,
          "style": { "size": 22, "color": "#00ffff", "font": "Inter-Regular" }
        },
        {
          "type": "qr",
          "x": 700,
          "y": 150,
          "size": 280,
          "label": "SCAN TO CONNECT",
          "labelStyle": { "size": 20, "color": "#94a3b8", "font": "Inter-Regular", "yOffset": 310 }
        }
      ]
    }
  }
}