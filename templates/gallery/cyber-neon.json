        { "type": "footer", "data": { "footerText": "// END_OF_TRANSMISSION" } }
      ]
    },
    "printableCard": {
      "layers": [
        { "type": "text", "content": "SYSTEM_ADMIN", "x": 50, "y": 50, "style": { "size": 32, "color": "white" } },
        { "type": "text", "content": "{{fullName}}", "x": 50, "y": 120, "style": { "size": 80, "color": "white" } },
