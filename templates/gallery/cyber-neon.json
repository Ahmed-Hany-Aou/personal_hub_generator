      "theme": "cyber",
      "components": [
        { "type": "profile", "data": { "profileImage": "https://api.dicebear.com/7.x/bottts/svg?seed=Cyber", "name": "{{fullName}}", "jobTitle": "CYBER_ARCHITECT" } },
        { "type": "cta-button", "data": { "label": "INITIATE CONTACT", "url": "#", "style": "pulse", "color": "#00ffcc" } },
