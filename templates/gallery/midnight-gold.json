        { "type": "profile", "data": { "profileImage": "https://api.dicebear.com/7.x/initials/svg?seed=Gold", "name": "{{fullName}}", "jobTitle": "Executive Director" } },
        { "type": "cta-button", "data": { "label": "Book a Consultation", "url": "#", "style": "pulse", "color": "#fbbf24" } },
