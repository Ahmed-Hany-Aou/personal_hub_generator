    "printableCard": {
      "layers": [
        { "type": "text", "content": "{{fullName}}", "x": 80, "y": 80, "style": { "size": 64, "color": "white" } },
        { "type": "text", "content": "EXECUTIVE", "x": 80, "y": 160, "style": { "size": 32, "color": "white" } },
        { "type": "qr", "x": 700, "y": 300, "size": 250 }
      ]
